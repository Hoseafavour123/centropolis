generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  clerkId       String   @unique
  email         String
  name          String?
  image         String?
  createdAt     DateTime @default(now())
  wallets       Wallet[]
  transactions  Transaction[]
  sentinelAnalyses SentinelAnalysis[]
  watchlists    Watchlist[]
  alerts           Alert[]
  plan             String   @default("FREE")
  role             String   @default("USER")
  twoFactorEnabled Boolean  @default(false)
  apiKeys          ApiKey[]
  notifications    Notification[]
}

model ApiKey {
  id         String   @id @default(uuid())
  userId     String
  key        String   @unique
  name       String
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String
  chain     String
  address   String
  nickname  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chain, address], name: "userId_chain_address")
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  chain       String
  type        String
  txHash      String?
  status      String   @default("PENDING") // PENDING, SUCCESS, FAILED, REFUNDED
  fromToken   String?
  toToken     String?
  fromAmount  Float?
  toAmount    Float?
  usdValue    Float?
  errorLogs   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SentinelAnalysis {
  id           String   @id
  tokenAddress String
  userId       String?
  result       Json?
  score        Int?
  status       String
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  chain     String
  address   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts Alert[]

  @@unique([userId, chain, address], name: "userId_chain_address")
}

model Alert {
  id             String   @id @default(uuid())
  watchlistId    String
  userId         String
  type           String   // 'PRICE_ABOVE', 'PRICE_BELOW', 'VOLUME_SPIKE', 'AI_RISK_HIGH'
  thresholdValue Float?
  status         String   @default("ACTIVE") // 'ACTIVE', 'TRIGGERED', 'PAUSED'
  createdAt      DateTime @default(now())

  watchlist      Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, DANGER
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  source    String?  // e.g., 'landing_page', 'referral'
  createdAt DateTime @default(now())
}
