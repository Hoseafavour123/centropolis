generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  clerkId       String   @unique
  email         String
  name          String?
  image         String?
  createdAt     DateTime @default(now())
  wallets       Wallet[]
  transactions  Transaction[]
  sentinelAnalyses SentinelAnalysis[]
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String
  chain     String
  address   String
  nickname  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chain, address], name: "userId_chain_address")
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  chain     String
  type      String
  txHash    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SentinelAnalysis {
  id           String   @id
  tokenAddress String
  userId       String?
  result       Json?
  score        Int?
  status       String
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
